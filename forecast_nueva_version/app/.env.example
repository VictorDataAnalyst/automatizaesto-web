# Copia este archivo como .env y rellena con los datos de tu proyecto Supabase.
# Sin estas variables, la app arranca en MODO DEMO (sin login, datos en RAM).
# Con ellas, arranca en MODO SAAS (Auth + persistencia + Storage).

# Dashboard → Settings → API
SUPABASE_URL=https://zbaaptweszjbqunscldb.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          # service_role key — SECRETO, nunca al frontend ni a git
SUPABASE_JWT_SECRET=          # Settings → API → JWT Secret (para validar tokens)

# Bucket privado de Storage para los archivos subidos (créalo en el dashboard)
FORECAST_BUCKET=forecast-datasets
