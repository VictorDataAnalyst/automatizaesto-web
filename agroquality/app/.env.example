# AgroQuality — variables de entorno.
# Sin estas variables, la app corre en MODO_DEMO (RAM, sin login).
# Con ellas, entra en MODO_SAAS (Supabase Auth + persistencia).
#
# Copia este archivo a .env (gitignoreado) y rellénalo con valores reales.
# Proyecto Supabase: automatizaesto-platform (el mismo de Forecast/AgroField).

SUPABASE_URL=https://TU-REF.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_KEY=tu-service-role-key
SUPABASE_JWT_SECRET=tu-jwt-secret

# Bucket privado para fotos de inspección (galería pallet/muestra).
AGROQUALITY_BUCKET=agroquality-fotos

# Solo para correr la migración con setup.py (no lo usa la app en runtime).
# Dashboard → botón "Connect" → Session pooler o Direct connection (puerto 5432).
# Reemplaza la contraseña; si tiene caracteres especiales, URL-encodéalos (ej. % -> %25).
SUPABASE_DB_URL=postgresql://postgres.TU-REF:TU-PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
